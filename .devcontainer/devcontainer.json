{
  "name": "Fortinet Ordering Guides",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // ── workspace ────────────────────────────────────────────────────────────────
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder}/ordering-guides,target=/workspace,type=bind",

  // ── mounts: pass Claude config & auth from host ──────────────────────────────
  "mounts": [
    // Claude Code auth tokens and config (persists login across rebuilds)
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/root/.claude,type=bind,consistency=cached",
    // Claude Code global settings
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/root/.claude.json,type=bind,consistency=cached"
  ],

  // ── environment ──────────────────────────────────────────────────────────────
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },

  // ── VS Code settings ─────────────────────────────────────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/usr/bin/zsh" }
        }
      }
    }
  },

  // ── post-create: confirm tools are ready ─────────────────────────────────────
  "postCreateCommand": "echo '✅ Ready' && claude --version && markitdown --version && echo 'workspace:' && ls /workspace",

  "remoteUser": "root"
}
